PORT=8080
HOST=0.0.0.0
BASE_URL=http://localhost:8080
STORAGE_DIR=./storage
YT_DLP_BIN=python
YT_DLP_ARGS=-m yt_dlp
FFMPEG_BIN=ffmpeg
MAX_JOB_AGE_MINUTES=60
# Use no Railway quando o YouTube retornar "Sign in to confirm you're not a bot".
# Gere o valor com:
# [Convert]::ToBase64String([IO.File]::ReadAllBytes("C:\caminho\youtube-cookies.txt"))
YOUTUBE_COOKIES_B64=
# Se o Railway recusar por limite de tamanho, divida em partes:
YOUTUBE_COOKIES_PART_1=
YOUTUBE_COOKIES_PART_2=
# Tambem funciona com Base64 dividido:
YOUTUBE_COOKIES_B64_PART_1=
YOUTUBE_COOKIES_B64_PART_2=
